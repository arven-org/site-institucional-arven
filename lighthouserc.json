{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "/",
        "/cases.html",
        "/servicos.html",
        "/sobre.html",
        "/qualificacao.html",
        "/templates.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.45 }],
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.75 }],
        "categories:seo": ["warn", { "minScore": 0.85 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
