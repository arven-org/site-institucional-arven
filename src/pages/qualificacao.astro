---
import Base from '../layouts/Base.astro';
import SchemaBreadcrumb from '../components/SchemaBreadcrumb.astro';
---
<Base
  title="Qualificação — Arven"
  description="Formulário para entendermos o momento do seu negócio. Envie suas respostas e nossa equipe retorna em breve."
  currentPage="qualificacao"
>

    <section class="lead-form-shell lead-form-shell--full" aria-labelledby="lead-form-title">
      <div class="lead-form-layout">

      <aside class="lead-form-aside" id="signal-aside" aria-hidden="true" data-reveal>
        <svg class="signal-svg" viewBox="0 0 280 330" width="280" height="330" overflow="visible">
          <!-- Ground grid -->
          <line class="sg-grid" x1="35" y1="312" x2="140" y2="325"/>
          <line class="sg-grid" x1="62" y1="302" x2="140" y2="315"/>
          <line class="sg-grid" x1="89" y1="292" x2="140" y2="305"/>
          <line class="sg-grid" x1="245" y1="312" x2="140" y2="325"/>
          <line class="sg-grid" x1="218" y1="302" x2="140" y2="315"/>
          <line class="sg-grid" x1="191" y1="292" x2="140" y2="305"/>
          <line class="sg-grid" x1="35" y1="312" x2="245" y2="312"/>
          <line class="sg-grid" x1="62" y1="302" x2="218" y2="302"/>
          <line class="sg-grid" x1="89" y1="292" x2="191" y2="292"/>
          <!-- Base platform -->
          <polygon class="sg-main" points="140,282 170,269 140,256 110,269"/>
          <!-- Main legs -->
          <line class="sg-main" x1="112" y1="267" x2="126" y2="127"/>
          <line class="sg-main" x1="168" y1="267" x2="154" y2="127"/>
          <!-- Horizontal rungs -->
          <line class="sg-main" x1="126" y1="127" x2="154" y2="127"/>
          <line class="sg-main" x1="124" y1="157" x2="156" y2="157"/>
          <line class="sg-main" x1="121" y1="192" x2="159" y2="192"/>
          <line class="sg-main" x1="117" y1="227" x2="163" y2="227"/>
          <line class="sg-main" x1="114" y1="255" x2="166" y2="255"/>
          <!-- Cross bracing -->
          <line class="sg-brace" x1="126" y1="127" x2="156" y2="157"/>
          <line class="sg-brace" x1="154" y1="127" x2="124" y2="157"/>
          <line class="sg-brace" x1="124" y1="157" x2="159" y2="192"/>
          <line class="sg-brace" x1="156" y1="157" x2="121" y2="192"/>
          <line class="sg-brace" x1="121" y1="192" x2="163" y2="227"/>
          <line class="sg-brace" x1="159" y1="192" x2="117" y2="227"/>
          <line class="sg-brace" x1="117" y1="227" x2="166" y2="255"/>
          <line class="sg-brace" x1="163" y1="227" x2="114" y2="255"/>
          <!-- Top platform -->
          <polygon class="sg-main" points="140,122 153,116 140,110 127,116"/>
          <!-- Antenna mast -->
          <line class="sg-main" x1="140" y1="110" x2="140" y2="36"/>
          <line class="sg-main" x1="132" y1="90" x2="148" y2="90"/>
          <line class="sg-main" x1="135" y1="68" x2="145" y2="68"/>
          <!-- Signal rings -->
          <circle class="signal-ring signal-ring--1" cx="140" cy="36" r="4"/>
          <circle class="signal-ring signal-ring--2" cx="140" cy="36" r="4"/>
          <circle class="signal-ring signal-ring--3" cx="140" cy="36" r="4"/>
          <circle class="signal-ring signal-ring--4" cx="140" cy="36" r="4"/>
          <!-- Antenna blinking dot -->
          <circle class="signal-antenna" cx="140" cy="33" r="3"/>
        </svg>
      </aside>

      <form id="arven-lead-form" class="lead-form" novalidate data-reveal data-reveal-delay="0.1">
        <div class="lead-form__hp" aria-hidden="true">
          <label for="lead-honeypot">Website</label>
          <input type="text" id="lead-honeypot" name="_honeypot" tabindex="-1" autocomplete="off" />
        </div>

        <div class="lead-form__progress-row">
          <div class="lead-form__circle-wrap">
            <svg class="lead-form__circle" viewBox="0 0 48 48" width="48" height="48">
              <defs>
                <linearGradient id="circleGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ffaa40"/>
                  <stop offset="100%" stop-color="#9c40ff"/>
                </linearGradient>
              </defs>
              <circle class="lead-form__circle-bg" cx="24" cy="24" r="20"/>
              <circle class="lead-form__circle-fill" cx="24" cy="24" r="20" data-lead-circle/>
            </svg>
            <span class="lead-form__circle-text" data-lead-step-label>1/8</span>
          </div>
          <div class="lead-form__progress" role="progressbar" aria-valuemin="1" aria-valuemax="8" aria-valuenow="1" aria-label="Progresso do formulário">
            <div class="lead-form__progress-fill"></div>
          </div>
        </div>

        <div class="lead-form__form-header">
          <p class="page-hero__tag">Contato</p>
          <h1 id="lead-form-title" class="page-hero__headline lead-form__page-headline">Preencha o formulário para entendermos o momento do seu negócio de forma personalizada.</h1>
        </div>

        <p class="lead-form__error" hidden role="alert">Preencha os campos obrigatórios para continuar.</p>

        <div class="lead-form__step" hidden data-step="nome">
          <label class="lead-form__label" for="lead-nome">Como podemos te chamar?</label>
          <input class="lead-form__input" id="lead-nome" name="nome" type="text" autocomplete="name" required placeholder="Nome completo" />
        </div>

        <div class="lead-form__step" hidden data-step="contato">
          <label class="lead-form__label" for="lead-email">E-mail profissional</label>
          <input class="lead-form__input" id="lead-email" name="email" type="email" autocomplete="email" required placeholder="voce@empresa.com.br" />
          <label class="lead-form__label lead-form__label--spaced" for="lead-wa">WhatsApp (com DDD)</label>
          <input class="lead-form__input" id="lead-wa" name="whatsapp" type="tel" autocomplete="tel" required placeholder="(49) 99999-9999" inputmode="tel" />
        </div>

        <div class="lead-form__step" hidden data-step="empresa">
          <label class="lead-form__label" for="lead-empresa">Nome da empresa ou projeto</label>
          <input class="lead-form__input" id="lead-empresa" name="empresa" type="text" autocomplete="organization" required placeholder="Ex.: Arven, holding, produto…" />
          <label class="lead-form__label lead-form__label--spaced" for="lead-site">Site ou Instagram (opcional)</label>
          <input class="lead-form__input" id="lead-site" name="site" type="text" placeholder="https:// ou @perfil" />
        </div>

        <div class="lead-form__step" hidden data-step="segmento">
          <label class="lead-form__label" for="lead-segmento">Qual descreve melhor seu negócio?</label>
          <select class="lead-form__select" id="lead-segmento" name="segmento" required>
            <option value="" disabled selected>Selecione…</option>
            <option value="consultoria">Consultoria / assessoria B2B</option>
            <option value="mentoria">Mentoria ou infoproduto B2B</option>
            <option value="advocacia">Escritório / serviços jurídicos</option>
            <option value="educacao">Educação corporativa ou ensino B2B</option>
            <option value="saas">SaaS ou tech B2B</option>
            <option value="servicos">Outros serviços B2B</option>
            <option value="outro">Outro</option>
          </select>
        </div>

        <div class="lead-form__step" hidden data-step="faturamento">
          <label class="lead-form__label" for="lead-fat">Faturamento mensal médio (ordem de grandeza)</label>
          <select class="lead-form__select" id="lead-fat" name="faturamento" required>
            <option value="" disabled selected>Selecione…</option>
            <option value="ate_100">Até R$ 100 mil</option>
            <option value="100_500">R$ 100 mil a R$ 500 mil</option>
            <option value="500_1m">R$ 500 mil a R$ 1 milhão</option>
            <option value="1m_3m">R$ 1 milhão a R$ 3 milhões</option>
            <option value="acima_3m">Acima de R$ 3 milhões</option>
            <option value="prefiro_nao">Prefiro não informar agora</option>
          </select>
        </div>

        <div class="lead-form__step" hidden data-step="midia">
          <label class="lead-form__label" for="lead-midia">Hoje vocês investem em mídia paga?</label>
          <select class="lead-form__select" id="lead-midia" name="midia" required>
            <option value="" disabled selected>Selecione…</option>
            <option value="sim_ativo">Sim, com orçamento ativo recorrente</option>
            <option value="sim_esporadico">Sim, mas de forma esporádica</option>
            <option value="nao">Ainda não investimos</option>
            <option value="nao_sei">Não sei dizer / time terceirizado</option>
          </select>
          <label class="lead-form__label lead-form__label--spaced" for="lead-midia-detalhe">Valor médio mensal em mídia ou contexto (opcional)</label>
          <textarea class="lead-form__textarea lead-form__textarea--short" id="lead-midia-detalhe" name="midia_detalhe" rows="2" placeholder="Ex.: ~R$ 30k/mês em Meta + Google"></textarea>
        </div>

        <div class="lead-form__step" hidden data-step="desafio">
          <label class="lead-form__label" for="lead-desafio">Qual é o maior desafio da operação de aquisição hoje?</label>
          <textarea class="lead-form__textarea" id="lead-desafio" name="desafio" rows="4" required placeholder="Ex.: CAC alto, lead ruim, marketing e vendas desalinhados…"></textarea>
          <label class="lead-form__label lead-form__label--spaced" for="lead-expectativa">O que você espera da Arven neste momento? (opcional)</label>
          <textarea class="lead-form__textarea lead-form__textarea--short" id="lead-expectativa" name="expectativa" rows="2" placeholder="Ex.: diagnóstico, operar mídia, funil inteiro…"></textarea>
        </div>

        <div class="lead-form__step" hidden data-step="revisao">
          <p class="lead-form__review-intro">Confira se está tudo certo. Ao clicar em confirmar envio, suas respostas serão registradas com segurança.</p>
          <dl class="lead-form__review" data-lead-review></dl>
        </div>

        <div class="lead-form__actions">
          <button type="button" class="btn btn--ghost" data-lead-action="prev" hidden>Voltar</button>
          <button type="button" class="btn btn--primary" data-lead-action="next">Continuar</button>
          <button type="button" class="btn btn--primary" data-lead-action="submit" hidden>Confirmar envio</button>
        </div>
      </form>

      <div
        id="lead-form-success"
        class="lead-form lead-form--success-panel"
        hidden
        role="status"
        aria-live="polite"
        aria-labelledby="lead-form-success-title"
      >
        <p id="lead-form-success-title" class="lead-form__success-title" tabindex="-1">
          Sua resposta ao formulário foi enviada com sucesso!!
        </p>
        <p class="lead-form__success-text">Nossa equipe retornará em breve pelo e-mail ou WhatsApp informados.</p>
        <a href="/" class="btn btn--primary lead-form__success-cta">Voltar ao início</a>
      </div>
      </div>
    </section>

    <Fragment slot="head">
      <SchemaBreadcrumb items={[
        { name: "Arven", url: "https://www.arvenoficial.com/" },
        { name: "Qualificação", url: "https://www.arvenoficial.com/qualificacao" }
      ]} />
    </Fragment>

</Base>

<script>
  import '../scripts/scroll-reveal.ts';
</script>

<script>
  import '../scripts/lead-form.ts';
</script>

<script>
  const form = document.getElementById('arven-lead-form');
  const aside = document.getElementById('signal-aside');
  if (form && aside) {
    form.addEventListener('focusin', function () { aside.classList.add('active'); });
    form.addEventListener('focusout', function () { aside.classList.remove('active'); });
  }
</script>
