---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { getAllPosts } from '../../lib/sanity.ts';

const posts = await getAllPosts();
const featured = posts.slice(0, 2);
const rest = posts.slice(2);
---
<Base
  title="Blog — Arven"
  description="A Arven desenha e opera funis de aquisição para empresas B2B. Do primeiro clique ao lead qualificado, pronto para o seu time fechar."
  currentPage="blog"
>
  <header class="page-hero page-hero--naked">
    <p class="page-hero__tag">Blog</p>
    <h1 class="page-hero__headline">Aquisição, qualificação e<br />processo comercial B2B.</h1>
    <p class="page-hero__sub">
      O que aprendemos operando funis de aquisição para dezenas de empresas.
      Sem teoria. Só o que funciona.
    </p>
  </header>

  {posts.length === 0 && (
    <section class="blog-empty">
      <h2 class="blog-empty__headline">Em breve</h2>
      <p class="blog-empty__sub">
        Estamos preparando os primeiros artigos. Conteúdo direto sobre aquisição B2B,
        escrito por quem opera isso todo dia.
      </p>
    </section>
  )}

  {posts.length > 0 && (
    <section class="blog-index">
      {/* Featured — 2 large cards */}
      <div class="blog-featured" data-reveal-stagger="0.1">
        {featured.map((post) => (
          <a href={`/blog/${post.slug.current}`} class="blog-featured__card" data-reveal-item>
            <div class="blog-featured__img-wrap">
              {post.image?.url ? (
                <img
                  src={`${post.image.url}?w=800&fm=webp`}
                  alt={post.image.alt ?? post.title}
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="blog-featured__placeholder" aria-hidden="true" />
              )}
            </div>
            <div class="blog-featured__body">
              <time class="blog-card__meta" datetime={post.publishedAt}>
                {new Date(post.publishedAt).toLocaleDateString('pt-BR', {
                  day: '2-digit', month: 'short', year: 'numeric'
                })}
              </time>
              <h2 class="blog-featured__title">{post.title}</h2>
              {post.excerpt && (
                <p class="blog-featured__excerpt">{post.excerpt}</p>
              )}
            </div>
          </a>
        ))}
      </div>

      {/* Rest — smaller 3-col grid with dividers */}
      {rest.length > 0 && (
        <div class="blog-rest" data-reveal-stagger="0.07">
          {rest.map((post) => (
            <a href={`/blog/${post.slug.current}`} class="blog-rest__card" data-reveal-item>
              <div class="blog-rest__img-wrap">
                {post.image?.url ? (
                  <img
                    src={`${post.image.url}?w=500&fm=webp`}
                    alt={post.image.alt ?? post.title}
                    width="500"
                    height="280"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="blog-rest__placeholder" aria-hidden="true" />
                )}
              </div>
              <div class="blog-rest__body">
                <time class="blog-card__meta" datetime={post.publishedAt}>
                  {new Date(post.publishedAt).toLocaleDateString('pt-BR', {
                    day: '2-digit', month: 'short', year: 'numeric'
                  })}
                </time>
                <h2 class="blog-rest__title">{post.title}</h2>
                {post.excerpt && (
                  <p class="blog-rest__excerpt">{post.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  )}
</Base>

<script>
  import '../../scripts/scroll-reveal.ts';
</script>
