---
import Base from '../layouts/Base.astro';
import SchemaBreadcrumb from '../components/SchemaBreadcrumb.astro';
---
<Base
  title="Resultados — Arven"
  description="Cases reais: CAC reduzido em 75%, ROAS 7x, leads qualificados a menos de R$25. Resultados de quem já opera com a assessoria Arven."
  currentPage="cases"
>

    <!-- HERO -->
    <section class="page-hero page-hero--cases">
      <div class="page-hero__inner">
        <div class="page-hero__copy">
          <p class="page-hero__tag">Resultados</p>
          <h1 class="page-hero__headline">Números de quem já opera<br class="br-md" />com a Arven.</h1>
          <p class="page-hero__sub">
            Cada número tem um contexto real, um cliente real e uma operação que ainda está ativa.
            Sem métricas de vaidade. Só o que importa: receita.
          </p>
        </div>
        <div class="icon-cloud-wrap">
          <canvas
            id="icon-cloud-canvas"
            class="icon-cloud-canvas"
            width="400"
            height="400"
            role="img"
            aria-label="Ferramentas do ecossistema de aquisição: Meta Ads, HubSpot, Google Drive, WhatsApp, Gemini, Claude, ChatGPT, Cursor, Kommo, Pipedrive, Google e X. Arraste para girar; clique num ícone para centralizar."
          ></canvas>
        </div>
      </div>
    </section>

    <!-- CASES EXPANDIDOS -->
    <div class="cases-list">

      <!-- QuartaVia -->
      <section class="case-detail" id="case-quartavia" data-reveal>
        <div class="case-detail__header">
          <div class="case-detail__heading">
            <img class="case-detail__logo" src="/assets/clients/quartavia-logo.svg" alt="QuartaVia" width="200" height="42" loading="lazy" decoding="async" />
            <div class="case-detail__client-row">
              <span class="case-detail__client">Consultoria patrimonial · Grupo QuartaVia</span>
              <a href="https://www.instagram.com/eu.adriancarvalho/" class="case-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Adrian Carvalho">
                <img src="/assets/icons/instagram.svg" alt="" width="16" height="16" decoding="async" />
              </a>
            </div>
          </div>
          <span class="case-detail__tag" data-tag="webinar">Webinar pago</span>
        </div>
        <div class="case-detail__body">
          <div class="case-detail__metrics">
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">ROAS 6,6</span>
              <span class="case-detail__metric-label">retorno sobre investimento em mídia</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">R$40M</span>
              <span class="case-detail__metric-label">faturados em 2024</span>
            </div>
          </div>
          <div class="case-detail__context case-detail__context--with-photo">
            <figure class="case-detail__spotlight case-detail__spotlight--aside">
              <img
                class="case-detail__spotlight-img"
                src="/assets/cases/adrian-quartavia.jpg"
                alt="Adrian, Grupo QuartaVia, em apresentação ao vivo"
                width="1024"
                height="1024"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="case-detail__spotlight-cap">Adrian · Grupo QuartaVia</figcaption>
            </figure>
            <div class="case-detail__context-main">
              <p class="case-detail__context-title">Contexto da operação</p>
              <div class="case-detail__desc">
                <p>
                  Funil de webinar pago com aquisição gerenciada pela Arven do início ao fim.
                  A operação foi desenhada para atrair investidores qualificados interessados
                  em estruturação patrimonial.
                </p>
                <p>
                  Ao longo de 12 meses, escalamos o investimento em mídia de forma controlada,
                  com otimização contínua de criativo, segmentação e processo de conversão
                  pós-webinar. Cada etapa do funil foi rastreada até o contrato fechado.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- EAG -->
      <section class="case-detail" id="case-eag" data-reveal>
        <div class="case-detail__header">
          <div class="case-detail__client-row">
            <span class="case-detail__client">EAG Educação — Marcelo Germano</span>
            <a href="https://www.instagram.com/marcelogermanoeag/" class="case-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Marcelo Germano">
              <img src="/assets/icons/instagram.svg" alt="" width="16" height="16" decoding="async" />
            </a>
          </div>
          <span class="case-detail__tag" data-tag="diagnostico">Diagnóstico</span>
        </div>
        <div class="case-detail__body">
          <div class="case-detail__metrics">
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">CAC -75%</span>
              <span class="case-detail__metric-label">redução no custo de aquisição</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">R$234</span>
              <span class="case-detail__metric-label">novo CAC (antes R$930)</span>
            </div>
          </div>
          <div class="case-detail__context case-detail__context--with-photo">
            <figure class="case-detail__spotlight case-detail__spotlight--aside">
              <img
                class="case-detail__spotlight-img case-detail__spotlight-img--portrait"
                src="/assets/cases/germano-eag.jpg"
                alt="Marcelo Germano, fundador da EAG Educação"
                width="683"
                height="1024"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="case-detail__spotlight-cap">Marcelo Germano · EAG Educação</figcaption>
            </figure>
            <div class="case-detail__context-main">
              <p class="case-detail__context-title">Contexto da operação</p>
              <div class="case-detail__desc">
                <p>
                  Operação de múltiplos 7 dígitos mensais com custo de aquisição fora de controle.
                  O diagnóstico revelou campanhas desconectadas do processo comercial e ausência
                  de rastreamento pós-lead.
                </p>
                <p>
                  Reestruturamos o funil completo: novas campanhas otimizadas por receita,
                  qualificação automatizada e integração direta com o CRM do time de vendas.
                  Em 7 meses, o CAC caiu 75% sem perda de volume.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CSC -->
      <section class="case-detail" id="case-csc" data-reveal>
        <div class="case-detail__header">
          <div class="case-detail__client-row">
            <span class="case-detail__client">CSC Advogados — Daniel Cheida</span>
            <a href="https://www.instagram.com/daniel.cheida/" class="case-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Daniel Cheida">
              <img src="/assets/icons/instagram.svg" alt="" width="16" height="16" decoding="async" />
            </a>
          </div>
          <span class="case-detail__tag" data-tag="evento">Evento presencial</span>
        </div>
        <div class="case-detail__body">
          <div class="case-detail__metrics">
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">ROAS 7</span>
              <span class="case-detail__metric-label">retorno sobre investimento em mídia</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">&lt; R$25</span>
              <span class="case-detail__metric-label">custo por lead qualificado</span>
            </div>
          </div>
          <div class="case-detail__context case-detail__context--with-photo">
            <figure class="case-detail__spotlight case-detail__spotlight--aside">
              <img
                class="case-detail__spotlight-img case-detail__spotlight-img--portrait"
                src="/assets/cases/daniel-csc.jpg"
                alt="Daniel Cheida, CSC Advogados"
                width="637"
                height="1024"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="case-detail__spotlight-cap">Daniel Cheida · CSC Advogados</figcaption>
            </figure>
            <div class="case-detail__context-main">
              <p class="case-detail__context-title">Contexto da operação</p>
              <div class="case-detail__desc">
                <p>
                  Estratégia integrada de mídia paga e evento presencial para o maior evento
                  de Direito Bancário High Ticket do Brasil. Funil completo de aquisição e
                  qualificação de participantes de alto valor.
                </p>
                <p>
                  A operação foi escalada múltiplas vezes mantendo eficiência.
                  O custo por lead qualificado se manteve consistentemente abaixo de R$25,
                  mesmo com aumento significativo de volume e investimento.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- APAE Brasil -->
      <section class="case-detail" id="case-apae" data-reveal>
        <div class="case-detail__header">
          <div class="case-detail__client-row">
            <span class="case-detail__client">APAE Brasil</span>
            <a href="https://www.instagram.com/apaebrasil/" class="case-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram da APAE Brasil">
              <img src="/assets/icons/instagram.svg" alt="" width="16" height="16" decoding="async" />
            </a>
          </div>
          <span class="case-detail__tag" data-tag="filantropia">Filantropia premiável</span>
        </div>
        <div class="case-detail__body">
          <div class="case-detail__metrics">
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">2025</span>
              <span class="case-detail__metric-label">pioneiros na filantropia de prêmios da rede nacional</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">Apae Noel</span>
              <span class="case-detail__metric-label">da campanha tradicional ao modelo digital de alta performance</span>
            </div>
          </div>
          <div class="case-detail__context case-detail__context--with-photo">
            <figure class="case-detail__spotlight case-detail__spotlight--aside">
              <img
                class="case-detail__spotlight-img"
                src="/assets/cases/apae-brasil.jpg"
                alt="Campanha Apae Noel: participante com capa e faixa verdes, projeto de filantropia premiável da APAE Brasil"
                width="1024"
                height="512"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="case-detail__spotlight-cap">APAE Brasil · Filantropia premiável</figcaption>
            </figure>
            <div class="case-detail__context-main">
              <p class="case-detail__context-title">Contexto da operação</p>
              <div class="case-detail__desc">
                <p>
                  Em 2025, fomos pioneiros junto à APAE Brasil ao impulsionar a filantropia de prêmios da rede.
                </p>
                <p>
                  O projeto modernizou a arrecadação por meio dos Títulos de Capitalização na modalidade
                  Filantropia Premiável. O grande diferencial foi transformar a tradicional campanha
                  &quot;Apae Noel&quot; em um modelo digital de alta performance.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Diego Faustino -->
      <section class="case-detail" id="case-diego-faustino" data-reveal>
        <div class="case-detail__header">
          <div class="case-detail__client-row">
            <span class="case-detail__client">Diego Faustino</span>
            <a href="https://www.instagram.com/diegofaustino68/" class="case-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Diego Faustino">
              <img src="/assets/icons/instagram.svg" alt="" width="16" height="16" decoding="async" />
            </a>
          </div>
          <span class="case-detail__tag" data-tag="trafego">Tráfego pago</span>
        </div>
        <div class="case-detail__body">
          <div class="case-detail__metrics">
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">Superbike</span>
              <span class="case-detail__metric-label">campeão brasileiro e referência em ações sorteadas no Brasil</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">7 dígitos</span>
              <span class="case-detail__metric-label">faturamento anual com ações no digital e dicas automotivas</span>
            </div>
            <div class="case-detail__metric">
              <span class="case-detail__metric-value">Top 10</span>
              <span class="case-detail__metric-label">influenciadores automotivos do Brasil</span>
            </div>
          </div>
          <div class="case-detail__context case-detail__context--with-photo">
            <figure class="case-detail__spotlight case-detail__spotlight--aside">
              <img
                class="case-detail__spotlight-img case-detail__spotlight-img--portrait"
                src="/assets/cases/diego-faustino.png"
                alt="Diego Faustino, campeão brasileiro de Superbike"
                width="238"
                height="452"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="case-detail__spotlight-cap">Diego Faustino · Campeão Brasileiro de Superbike</figcaption>
            </figure>
            <div class="case-detail__context-main">
              <p class="case-detail__context-title">Contexto da operação</p>
              <div class="case-detail__desc">
                <p>
                  Campeão Brasileiro de Superbike, líder no mercado de ações sorteadas no Brasil.
                </p>
                <p>
                  Múltiplos 7 dígitos faturados anualmente com suas ações no digital e dicas automotivas.
                </p>
                <p>
                  Top 10 entre influenciadores automotivos do Brasil.
                </p>
                <p>
                  Fomos a assessoria responsável por levar as ações do Diego Faustino oficialmente ao tráfego pago.
                  Onde antes a receita vinha somente de forma orgânica, hoje construímos uma máquina de escala que roda sem parar.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- CTA FINAL -->
    <section class="cta-final" data-reveal>
      <div class="cta-final__inner">
        <h2 class="cta-final__headline">Quer resultados como esses<br class="br-md" />na sua operação?</h2>
        <p class="cta-final__sub">
          Fazemos um diagnóstico da sua operação atual sem custo.
          Você sai com clareza sobre onde está o gargalo e o que faz sentido resolver primeiro.
        </p>
        <a href="/qualificacao" class="btn btn--primary">Solicitar diagnóstico</a>
      </div>
    </section>

    <Fragment slot="head">
      <SchemaBreadcrumb items={[
        { name: "Arven", url: "https://www.arvenoficial.com/" },
        { name: "Resultados", url: "https://www.arvenoficial.com/cases" }
      ]} />
    </Fragment>

</Base>

<script>
  import '../scripts/scroll-reveal.ts';
</script>

<script>
  import { init } from '../scripts/icon-cloud.ts';

  const canvas = document.getElementById('icon-cloud-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const urls = [
      "/assets/icons/meta.svg",
      "/assets/icons/hubspot.svg",
      "/assets/icons/googledrive.svg",
      "/assets/icons/whatsapp.svg",
      "/assets/icons/googlegemini.svg",
      "/assets/icons/anthropic.svg",
      "/assets/icons/openai.svg",
      "/assets/icons/cursor.svg",
      "/assets/icon-cloud/kommo.svg",
      "/assets/icon-cloud/pipedrive.svg",
      "/assets/icons/google.svg",
      "/assets/icons/x.svg"
    ];
    init(canvas, urls);
  }
</script>
