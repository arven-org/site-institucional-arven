---
import Base from '../layouts/Base.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';
import { getRecentPosts } from '../lib/sanity.ts';

let recentPosts: Awaited<ReturnType<typeof getRecentPosts>> = [];
try {
  recentPosts = await getRecentPosts(3);
} catch {
  // Sanity unavailable — section won't render
}
---
<Base
  title="Arven — Assessoria de Aquisição"
  description="A Arven desenha e opera funis de aquisição para empresas B2B. Do primeiro clique ao lead qualificado, pronto para o seu time fechar."
  currentPage="index"
>

    <!-- HERO -->
    <section class="hero">
      <div class="hero__inner">
        <div class="hero__lead">
          <p class="hero__tag">Assessoria de Aquisição</p>
          <h1 class="hero__headline">
            <span class="sr-only">Reuniões qualificadas com os compradores certos. Uma operação inteira dedicada ao seu pipeline.</span>
            <span class="hero__lines" aria-hidden="true">
              <span class="hero__line">Reuniões qualificadas</span>
              <span class="hero__line">com os compradores certos.</span>
              <span class="hero__line">Uma operação inteira dedicada</span>
              <span class="hero__line">ao seu pipeline.</span>
            </span>
          </h1>
        </div>

        <div class="hero__viz">
          <ul class="hero-funnel" aria-label="Etapas da operação: da demanda ao fechamento">
            <li class="hero-funnel__step">
              <span class="hero-funnel__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              </span>
              <span class="hero-funnel__label">Demanda</span>
            </li>
            <li class="hero-funnel__step">
              <span class="hero-funnel__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </span>
              <span class="hero-funnel__label">Leads qualificados</span>
            </li>
            <li class="hero-funnel__step">
              <span class="hero-funnel__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>
              </span>
              <span class="hero-funnel__label">Dados automatizados</span>
            </li>
            <li class="hero-funnel__step">
              <span class="hero-funnel__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01M8 18h.01M12 18h.01"/></svg>
              </span>
              <span class="hero-funnel__label">Agendamento de calls</span>
            </li>
            <li class="hero-funnel__step">
              <span class="hero-funnel__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
              </span>
              <span class="hero-funnel__label">Fechamentos</span>
            </li>
          </ul>
          <p class="hero-funnel__caption"><strong>Um funil só.</strong> Do clique ao contrato.</p>
        </div>

        <div class="hero__rest">
          <p class="hero__sub">
            A Arven desenha e opera funis de aquisição usando dados e tecnologia.
            Do primeiro clique ao lead qualificado, pronto para o seu time fechar.
          </p>
          <div class="hero__social-proof">
            <div class="avatar-circles" aria-hidden="true">
              <img class="avatar-circles__img" src="/assets/cases/diego-faustino-thumb.webp"   alt="" width="40" height="40" decoding="async" />
              <img class="avatar-circles__img" src="/assets/cases/germano-eag-thumb.webp"       alt="" width="40" height="40" decoding="async" />
              <img class="avatar-circles__img" src="/assets/cases/daniel-csc-thumb.webp"        alt="" width="40" height="40" decoding="async" />
              <img class="avatar-circles__img" src="/assets/cases/adrian-quartavia-thumb.webp"  alt="" width="40" height="40" decoding="async" />
<span class="avatar-circles__more">+50</span>
            </div>
            <p class="hero__social-label">empresas que já escalaram com a Arven</p>
          </div>

          <div class="hero__cta-row">
            <a href="/qualificacao" class="btn btn--primary">Solicitar diagnóstico</a>
            <a href="/qualificacao" class="btn btn--ghost">Ver cases de resultado</a>
          </div>
        </div>
      </div>
    </section>

    <!-- NÚMEROS -->
    <section class="numbers">
      <div class="numbers__grid" data-reveal-stagger="0.1">
        <div class="numbers__item" data-reveal-item>
          <span class="numbers__value"><span>R$</span><span data-ticker="10">10</span><span>M</span></span>
          <span class="numbers__label">geridos mensalmente em mídia paga</span>
        </div>
        <div class="numbers__item" data-reveal-item>
          <span class="numbers__value"><span data-ticker="50" data-ticker-suffix="+">50+</span></span>
          <span class="numbers__label">operações de aquisição ativas</span>
        </div>
        <div class="numbers__item" data-reveal-item>
          <span class="numbers__value"><span>R$</span><span data-ticker="40">40</span><span>M+</span></span>
          <span class="numbers__label">em mídia gerenciada ao longo da carreira</span>
        </div>
      </div>
    </section>

    <!-- FRAMEWORK — O PONTO DE RESULTADO -->
    <section class="framework">
      <div class="framework__head" data-reveal>
        <h2 class="framework__headline">O Ponto de Resultado</h2>
        <p class="framework__sub">Cada decisão na operação aponta para um único lugar. Essa é a lente com que enxergamos cada operação que gerenciamos.</p>
      </div>

      <div class="framework__focal" data-reveal>
        <span class="framework__focal-label">objetivo central</span>
        <span class="framework__focal-value">Receita</span>
      </div>

      <div class="framework__connector"></div>

      <div class="framework__pillars" data-reveal-stagger>
        <div class="framework__pillar" data-reveal-item>
          <p class="framework__pillar-tag">Público-Alvo</p>
          <p class="framework__pillar-desc">Responsável por mais de 85% das conversões. A definição precisa de quem compra determina todo o restante da operação.</p>
        </div>
        <div class="framework__pillar" data-reveal-item>
          <p class="framework__pillar-tag">Funil</p>
          <p class="framework__pillar-desc">Condução do lead do primeiro contato até a decisão de compra. Cada etapa desenhada, medida e otimizada.</p>
        </div>
        <div class="framework__pillar" data-reveal-item>
          <p class="framework__pillar-tag">Canal</p>
          <p class="framework__pillar-desc">Os canais que geram demanda real para o produto. Escolhidos e priorizados por dados, não por tendência.</p>
        </div>
        <div class="framework__pillar" data-reveal-item>
          <p class="framework__pillar-tag">LTV</p>
          <p class="framework__pillar-desc">Tempo e valor que um cliente permanece na base. Determina quanto faz sentido investir para adquirir.</p>
        </div>
      </div>

      <div class="framework__metrics" data-reveal-stagger>
        <div class="framework__metric" data-reveal-item>
          <p class="framework__metric-tag">CAC</p>
          <p class="framework__metric-desc">Custo de aquisição de clientes</p>
        </div>
        <div class="framework__metric" data-reveal-item>
          <p class="framework__metric-tag">COGS</p>
          <p class="framework__metric-desc">Margem bruta do produto</p>
        </div>
        <div class="framework__metric" data-reveal-item>
          <p class="framework__metric-tag">MQL</p>
          <p class="framework__metric-desc">Leads dentro do perfil ideal de cliente</p>
        </div>
        <div class="framework__metric" data-reveal-item>
          <p class="framework__metric-tag">Conversão</p>
          <p class="framework__metric-desc">Taxa de conversão de MQLs para venda</p>
        </div>
      </div>
    </section>

    <!-- MÉTODO -->
    <section class="method method--light" id="metodo">
      <div class="method__head">
        <div class="method__intro">
          <h2 class="method__headline">Quatro etapas. Uma operação<br class="br-md" />construída para escalar com você.</h2>
          <p class="method__sub">Construímos e gerenciamos a máquina de demanda do seu negócio, do zero ou dentro do que você já tem.</p>
        </div>
        <a href="/qualificacao" class="btn btn--method-light method__cta">Ver serviços</a>
      </div>
      <div class="method__steps" data-reveal-stagger="0.1">
        <div class="step" data-reveal-item>
          <p class="step__num">01. Análise</p>
          <h3 class="step__title">Leitura completa da operação</h3>
          <p class="step__desc">Mapeamos público-alvo, funil atual, CAC, LTV e canais. Identificamos onde está o gargalo antes de investir um real.</p>
        </div>
        <div class="step" data-reveal-item>
          <p class="step__num">02. Execução</p>
          <h3 class="step__title">Estratégia implementada pelo nosso time</h3>
          <p class="step__desc">Campanhas em qualquer fonte de tráfego, funil estruturado e CRM implementado. Sem custo adicional por tipo de campanha ou volume investido.</p>
        </div>
        <div class="step" data-reveal-item>
          <p class="step__num">03. Acompanhamento</p>
          <h3 class="step__title">Visibilidade total em tempo real</h3>
          <p class="step__desc">Dashboard exclusivo de marketing e vendas, reuniões semanais de alinhamento e reports automatizados. Você sabe exatamente o que está acontecendo.</p>
        </div>
        <div class="step" data-reveal-item>
          <p class="step__num">04. Otimização</p>
          <h3 class="step__title">A operação melhora todo mês</h3>
          <p class="step__desc">Análise pós-implementação contínua. Os dados de cada ciclo alimentam a próxima decisão. A máquina aprende junto com o negócio.</p>
        </div>
      </div>
    </section>

    <!-- VSL + CTA: desktop 1920×1080 em vsl-arven.mp4; mobile 1080×1920 em vsl-arven-mobile.mp4 (origem Desktop: vsl_site_arven_mobile.mp4) -->
    <section class="statement-video" id="mensagem">
      <div class="statement-video__inner">
        <div class="statement-video__cta" data-reveal>
          <h2 class="statement-video__title">Tenha acesso ao time de performance. <span class="statement-video__title--dim">Responsável por grandes cases do mercado.</span></h2>
          <p class="statement-video__desc">
            Se você trabalha com <span class="text-highlight">consultoria</span>, <span class="text-highlight">mentoria</span> ou é <span class="text-highlight">advogado</span>, conheça nossos serviços em detalhe e, quando fizer sentido, agende um diagnóstico da sua operação. Sem custo e com clareza sobre o próximo passo.
          </p>
          <div class="statement-video__actions">
            <a href="/qualificacao" class="btn btn--primary">Conhecer nossos serviços</a>
            <a href="/qualificacao" class="btn btn--ghost">Agendar call</a>
          </div>
        </div>
        <div class="statement-video__media-col">
          <div class="statement-video__frame" data-vsl-root role="group" aria-label="Vídeo VSL da Arven">
            <div class="statement-video__viewport">
              <video
                class="statement-video__media"
                data-vsl-player
                data-vsl-src-desktop="/assets/video/vsl-arven.mp4"
                data-vsl-src-mobile="/assets/video/vsl-arven-mobile.mp4"
                data-vsl-poster-desktop="/assets/video/vsl-arven-poster.jpg"
                data-vsl-poster-mobile="/assets/video/vsl-arven-mobile-poster.jpg"
                poster="/assets/video/vsl-arven-poster.jpg"
                playsinline
                preload="none"
                disablepictureinpicture
              >
                <source src="/assets/video/vsl-arven.mp4" type="video/mp4" />
              </video>
              <div class="statement-video__buffering" aria-hidden="true"></div>
              <div class="vsl-overlay" data-vsl-overlay aria-hidden="true">
                <div class="vsl-overlay__ring">
                  <div class="vsl-overlay__btn">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div class="statement-video__chrome">
                <div class="statement-video__tracks">
                  <div class="statement-video__track">
                    <div class="statement-video__buffer-fill" data-vsl-buffer></div>
                    <div class="statement-video__progress-fill" data-vsl-progress></div>
                  </div>
                </div>
                <div class="statement-video__toolbar">
                  <button type="button" class="statement-video__btn statement-video__play" data-vsl-play aria-label="Reproduzir">
                    <svg class="statement-video__icon statement-video__icon--play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
                    <svg class="statement-video__icon statement-video__icon--pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
                  </button>
                  <span class="statement-video__time" data-vsl-time>0:00 / 0:00</span>
                  <a href="https://www.instagram.com/lassenrf/" class="statement-video__ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Rafael Lassen">
                    <img src="/assets/icons/instagram.svg" alt="" width="20" height="20" decoding="async" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="faq" aria-labelledby="faq-heading">
      <div class="faq__inner">
        <header class="faq__head" data-reveal>
          <p class="faq__tag">Dúvidas</p>
          <h2 id="faq-heading" class="faq__headline">Perguntas frequentes</h2>
          <p class="faq__sub">Respostas diretas sobre como trabalhamos e o que você pode esperar da assessoria.</p>
        </header>
        <div class="faq__list" data-reveal-stagger="0.06">
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">O que é assessoria de aquisição?</summary>
            <div class="faq__a">
              <p>É a operação que une estratégia, mídia paga, funil, CRM e dados para gerar demanda qualificada e entregar leads prontos para o seu time comercial fechar. Do primeiro clique ao agendamento, com uma visão única da operação.</p>
            </div>
          </details>
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">Para quem a Arven faz sentido?</summary>
            <div class="faq__a">
              <p>Negócios B2B e de ticket médio alto: consultoria, educação, serviços profissionais, SaaS e empresas que dependem de reuniões ou propostas para vender. Se a aquisição é o gargalo do crescimento, costumamos ser um bom encaixe.</p>
            </div>
          </details>
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">Como funciona o diagnóstico gratuito?</summary>
            <div class="faq__a">
              <p>Você entra em contato, alinhamos contexto e analisamos sua operação atual: público, funil, canais e números. Você sai com clareza sobre onde está o gargalo e o que faria sentido atacar primeiro, sem compromisso de contratar.</p>
            </div>
          </details>
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">Vocês cuidam só de anúncios ou do funil inteiro?</summary>
            <div class="faq__a">
              <p>Do funil inteiro: campanhas, páginas, automações, integração com CRM, qualificação e ritmo com o comercial quando o projeto pede. Não somos só gestão de tráfego isolada. Desenhamos e operamos a máquina de demanda como um sistema.</p>
            </div>
          </details>
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">E se eu já tiver time de marketing ou agência?</summary>
            <div class="faq__a">
              <p>Podemos assumir a operação ponta a ponta ou complementar onde falta profundidade (dados, funil, integração com vendas). O diagnóstico mostra o que já está maduro e onde a Arven entrega mais alavancagem.</p>
            </div>
          </details>
          <details class="faq__item" data-reveal-item>
            <summary class="faq__q">Como funciona investimento e contrato?</summary>
            <div class="faq__a">
              <p>O modelo e o valor dependem do escopo da operação e do estágio do negócio. Isso só dá para cravar depois do diagnóstico. Em geral trabalhamos com retainer de assessoria; mídia é budget à parte, transparente e sob sua conta.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    {recentPosts.length > 0 && (
      <section class="blog-preview">
        <div class="blog-preview__head">
          <div>
            <p class="blog-preview__tag">Blog</p>
            <h2 class="blog-preview__headline">Do que aprendemos<br class="br-md" />operando funis de aquisição</h2>
          </div>
          <a href="/blog" class="btn btn--ghost">Ver todos os artigos</a>
        </div>
        <div class="blog-preview__grid" data-reveal-stagger>
          {recentPosts.map((post) => (
            <a href={`/blog/${post.slug.current}`} class="blog-preview__card" data-reveal-item>
              <div class="blog-preview__img-wrap">
                {post.image?.url ? (
                  <img
                    src={`${post.image.url}?w=600&fm=webp`}
                    alt={post.image.alt ?? post.title}
                    width="600"
                    height="338"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div style="width:100%;height:100%;background:var(--bg-raised);" />
                )}
              </div>
              <div class="blog-preview__info">
                <time class="blog-preview__date" datetime={post.publishedAt}>
                  {new Date(post.publishedAt).toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric',
                  })}
                </time>
                <h3 class="blog-preview__title">{post.title}</h3>
                {post.excerpt && (
                  <p class="blog-preview__excerpt">{post.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA FINAL -->
    <section class="cta-final magic-card" id="diagnostico" data-magic-card>
      <div class="magic-card__spotlight" aria-hidden="true"></div>
      <div class="cta-final__inner" data-reveal>
        <h2 class="cta-final__headline">Pronto para ter uma operação<br class="br-md" />de aquisição de alto nível?</h2>
        <p class="cta-final__sub">
          Fazemos um diagnóstico da sua operação atual sem custo.
          Você sai com clareza sobre onde está o gargalo e o que faz sentido resolver primeiro.
        </p>
        <a href="/qualificacao" class="btn btn--primary">Solicitar diagnóstico</a>
      </div>
    </section>

    <Fragment slot="head">
      <SchemaFAQ faqs={[
        {
          question: "O que é assessoria de aquisição?",
          answer: "É a operação que une estratégia, mídia paga, funil, CRM e dados para gerar demanda qualificada e entregar leads prontos para o seu time comercial fechar. Do primeiro clique ao agendamento, com uma visão única da operação."
        },
        {
          question: "Para quem a Arven faz sentido?",
          answer: "Negócios B2B e de ticket médio alto: consultoria, educação, serviços profissionais, SaaS e empresas que dependem de reuniões ou propostas para vender. Se a aquisição é o gargalo do crescimento, costumamos ser um bom encaixe."
        },
        {
          question: "Como funciona o diagnóstico gratuito?",
          answer: "Você entra em contato, alinhamos contexto e analisamos sua operação atual: público, funil, canais e números. Você sai com clareza sobre onde está o gargalo e o que faria sentido atacar primeiro, sem compromisso de contratar."
        },
        {
          question: "Vocês cuidam só de anúncios ou do funil inteiro?",
          answer: "Do funil inteiro: campanhas, páginas, automações, integração com CRM, qualificação e ritmo com o comercial quando o projeto pede. Não somos só gestão de tráfego isolada. Desenhamos e operamos a máquina de demanda como um sistema."
        },
        {
          question: "E se eu já tiver time de marketing ou agência?",
          answer: "Podemos assumir a operação ponta a ponta ou complementar onde falta profundidade (dados, funil, integração com vendas). O diagnóstico mostra o que já está maduro e onde a Arven entrega mais alavancagem."
        },
        {
          question: "Como funciona investimento e contrato?",
          answer: "O modelo e o valor dependem do escopo da operação e do estágio do negócio. Isso só dá para cravar depois do diagnóstico. Em geral trabalhamos com retainer de assessoria; mídia é budget à parte, transparente e sob sua conta."
        }
      ]} />
    </Fragment>

</Base>

<style>
  .hero__social-proof {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
    animation: fadeUp 0.55s ease 1.22s both;
  }

  .avatar-circles {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .avatar-circles__img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--bg);
    object-fit: cover;
    object-position: top center;
    display: block;
    margin-left: -10px;
  }

  .avatar-circles__img:first-child {
    margin-left: 0;
  }

  .avatar-circles__more {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--bg);
    background: var(--bg-raised);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    font-family: var(--font-mono);
    margin-left: -10px;
    flex-shrink: 0;
  }

  .hero__social-label {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.4;
    max-width: 180px;
  }
</style>

<script>
  import '../scripts/vsl-player.ts';
</script>

<script>
  import '../scripts/number-ticker.ts';
</script>

<script>
  import '../scripts/magic-card.ts';
</script>

<script>
  import '../scripts/scroll-reveal.ts';
</script>

<script>
  import '../scripts/faq-accordion.ts';
</script>

