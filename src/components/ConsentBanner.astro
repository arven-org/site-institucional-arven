---
/**
 * Banner de consentimento (LGPD).
 * - Aparece somente se nao houver decisao previa em cookie.
 * - "Aceitar" chama window.ArvenAttribution.grantConsent()
 *   (migra session -> localStorage, persiste 90 dias).
 * - "Recusar" chama revokeConsent() e marca cookie arven_consent=denied
 *   (banner some, atribuicao continua em sessionStorage).
 * - Render inicial via inline script: evita flash na primeira pintura.
 */
---
<div
  id="arven-consent"
  class="arven-consent"
  role="dialog"
  aria-modal="false"
  aria-labelledby="arven-consent-title"
  aria-describedby="arven-consent-body"
  hidden
>
  <div class="arven-consent__card">
    <div class="arven-consent__text">
      <p id="arven-consent-title" class="arven-consent__title">Cookies e medição</p>
      <p id="arven-consent-body" class="arven-consent__body">
        Usamos cookies estritamente necessários e, com sua autorização,
        identificadores de campanha (UTMs, gclid, fbclid) para entender
        quais ações de marketing trazem os clientes certos.
        Sua decisão fica salva por 90 dias.
        <a href="/politica-de-privacidade" class="arven-consent__link">Saiba mais</a>.
      </p>
    </div>
    <div class="arven-consent__actions">
      <button type="button" class="arven-consent__btn arven-consent__btn--ghost" data-arven-consent="deny">
        Recusar
      </button>
      <button type="button" class="arven-consent__btn arven-consent__btn--primary" data-arven-consent="accept">
        Aceitar
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var COOKIE = "arven_consent";

    function readCookie() {
      var parts = document.cookie.split(";");
      for (var i = 0; i < parts.length; i++) {
        var p = parts[i].trim();
        if (p.indexOf(COOKIE + "=") === 0) return p.substring(COOKIE.length + 1);
      }
      return "";
    }

    function setCookie(value) {
      var maxAge = 90 * 24 * 60 * 60;
      document.cookie = COOKIE + "=" + value + "; Max-Age=" + maxAge + "; Path=/; SameSite=Lax";
    }

    function hide(banner) {
      banner.setAttribute("hidden", "");
      banner.classList.remove("arven-consent--visible");
    }

    function show(banner) {
      banner.removeAttribute("hidden");
      // dois frames pra garantir transicao a partir do estado oculto
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          banner.classList.add("arven-consent--visible");
        });
      });
    }

    function mount() {
      var banner = document.getElementById("arven-consent");
      if (!banner) return;

      var existing = readCookie();
      if (existing === "granted" || existing === "denied") {
        // ja decidiu — garante que a flag global reflita a decisao
        if (existing === "granted" && window.ArvenAttribution) {
          window.ArvenAttribution.grantConsent();
        }
        return;
      }

      show(banner);

      banner.addEventListener("click", function (e) {
        var t = e.target;
        if (!(t instanceof HTMLElement)) return;
        var action = t.getAttribute("data-arven-consent");
        if (!action) return;

        if (action === "accept") {
          setCookie("granted");
          if (window.ArvenAttribution) window.ArvenAttribution.grantConsent();
        } else if (action === "deny") {
          setCookie("denied");
          if (window.ArvenAttribution) window.ArvenAttribution.revokeConsent();
        }
        hide(banner);
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mount, { once: true });
    } else {
      mount();
    }
  })();
</script>

<style>
  .arven-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px;
    pointer-events: none;
  }

  .arven-consent__card {
    max-width: 720px;
    margin: 0 auto;
    background: rgba(17, 17, 17, 0.92);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4), 0 2px 8px rgba(0, 0, 0, 0.2);
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 280ms cubic-bezier(0.16, 1, 0.3, 1),
                transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .arven-consent--visible .arven-consent__card {
    opacity: 1;
    transform: translateY(0);
  }

  .arven-consent__text {
    flex: 1;
  }

  .arven-consent__title {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .arven-consent__body {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .arven-consent__link {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-hover);
    text-underline-offset: 3px;
    transition: text-decoration-color 160ms ease;
  }

  .arven-consent__link:hover {
    text-decoration-color: var(--text-primary);
  }

  .arven-consent__actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .arven-consent__btn {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.005em;
    padding: 9px 16px;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
    white-space: nowrap;
  }

  .arven-consent__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .arven-consent__btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--border);
  }

  .arven-consent__btn--ghost:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  .arven-consent__btn--primary {
    background: var(--text-primary);
    color: var(--bg);
    border-color: var(--text-primary);
  }

  .arven-consent__btn--primary:hover {
    background: #ffffff;
    border-color: #ffffff;
  }

  @media (min-width: 640px) {
    .arven-consent__card {
      flex-direction: row;
      align-items: center;
      gap: 24px;
      padding: 16px 18px 16px 22px;
    }
    .arven-consent__body {
      font-size: 13px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .arven-consent__card {
      transition: none;
      transform: none;
    }
  }
</style>
